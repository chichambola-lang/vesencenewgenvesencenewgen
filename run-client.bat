@echo off
cd /d "%~dp0"

REM ─────────────────────────────────────────────────────────────────────────
REM Перед запуском гасим возможные "залипшие"/повреждённые Gradle-демоны.
REM Именно их повторное использование вызывало периодическую ошибку
REM "class java.lang.Integer cannot be cast to class java.lang.String" на
REM этапе конфигурации сборки (демон из прошлого запуска ловил рассинхрон
REM состояния). Чистый старт демона эту проблему устраняет.
REM ─────────────────────────────────────────────────────────────────────────
call gradlew.bat --stop

call gradlew.bat runClient
pause
